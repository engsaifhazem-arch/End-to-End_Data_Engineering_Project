# ============================================================
# .gitignore for Olist Data Engineering Project
# ============================================================

# ============================================================
# 1. VISUAL STUDIO / SSIS / SSAS
# ============================================================

# Visual Studio temporary files
.vs/
*.suo
*.user
*.userosscache
*.sln.docstates
*.dbmdl
*.jfm
*.obj
*.pdb
*.vshost.exe
*.vshost.exe.manifest
*.tmp
*.cache
*.log

# SSIS package cache
*.ispac
*.deploymentmanifest
*.dtsx.orig
*.dtsx.proj
*.dtsx.user

# SSAS model cache
*.bim.orig
*.bim.user
*.bim.proj
*.asdatabase

# SQL Server Data Tools
*.dtproj.user
*.database
*.dbproj.user
*.sqlproj.user

# ============================================================
# 2. POWER BI
# ============================================================

# Power BI temporary files
*.pbi
*.pbix
*.pbix.orig
*.pbit
*.pbit.orig
*.pbixproj.user
*.pbixproj.proj

# Power BI cache
*.pbix.cache
*.pbix.lock
*.pbi.lock

# ============================================================
# 3. SQL SERVER
# ============================================================

# SQL Server data files
*.mdf
*.ldf
*.ndf
*.bak
*.trn
*.log

# SQL Server Management Studio
*.sqluser
*.sqlsettings
*.sos

# ============================================================
# 4. DATA FILES
# ============================================================

# CSV files (optional - uncomment if you want to exclude them)
# *.csv
# *.tsv
# *.txt

# Compressed files
*.zip
*.rar
*.7z
*.tar
*.gz

# ============================================================
# 5. SYSTEM FILES
# ============================================================

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
*.tmp
*.bak
*.old
*.orig

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Linux
*~
.directory
*.swp
*.swo

# ============================================================
# 6. SECURITY
# ============================================================

# Credentials
*.pwd
*.key
*.cert
*.pfx
*.p12
connection_strings.txt
.env
secrets.json
secrets.config

# ============================================================
# 7. BUILD AND DEPLOYMENT
# ============================================================

# Build outputs
/bin/
/obj/
/Debug/
/Release/
/packages/
*.nupkg

# ============================================================
# 8. MISCELLANEOUS
# ============================================================

# Backup files
*.backup
*.backup.*
*.old
*.orig

# Log files
*.log
*.err
*.out

# IDE settings
*.idea/
*.vscode/
*.code-workspace
